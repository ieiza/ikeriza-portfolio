---
import { getCollection } from "astro:content";
import Navbar from "../../components/Navbar.astro";

export async function getStaticPaths() {
    const projectEntries = await getCollection("projects");
    return projectEntries.map((entry) => ({
        params: { id: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { title, heroImage, heroVideo, heroType, mediaGrid } = entry.data;

// Calculate Next Project for Footer Navigation
const allProjects = await getCollection("projects");
const currentIndex = allProjects.findIndex((p) => p.id === entry.id);
const nextIndex = (currentIndex + 1) % allProjects.length;
const nextProject = allProjects[nextIndex];

// Determine whether hero media should render as a video or image
const isHeroVideo =
    heroType === "video" ||
    Boolean(heroVideo) ||
    heroImage?.match(/\.(mp4|webm|mov)$/i);
const heroVideoSrc = heroVideo || heroImage;

const currentGrid = mediaGrid || [
    { type: "image", src: heroImage, span: 2 },
    { type: "placeholder", title: "PROCESS ARTIFACT", span: 2 },
    { type: "image", src: heroImage, span: 1 },
];
---

<!doctype html>
<html lang="en-US">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title} — Portfolio</title>

        <!-- Adobe Typekit Font Sync -->
        <link rel="stylesheet" href="https://use.typekit.net/lmi7yvo.css" />

        <!-- Global CSS links mapped directly from static public endpoints -->
        <link rel="stylesheet" href="/assets/css/style.css" />
        <link rel="stylesheet" href="/assets/css/plyr.css" />
    </head>
    <body class="body">
        <Navbar />

        <main class="project-main-viewport">
            <!-- Section 1: Hero Block Header -->
            <header class="project-hero-header">
                <div class="hero-bg-frame">
                    {
                        isHeroVideo ? (
                            <video
                                autoplay
                                loop
                                muted
                                playsinline
                                class="hero-cover-src"
                            >
                                <source src={heroVideoSrc} type="video/mp4" />
                            </video>
                        ) : (
                            <img
                                src={heroImage}
                                alt={`${title} Landscape Backdrop`}
                                class="hero-cover-src"
                            />
                        )
                    }
                </div>
                <div class="hero-title-overlay">
                    <h1 class="h1-global-title hero-dynamic-title">
                        {title}
                    </h1>
                </div>
            </header>

            <!-- Section 2: Dynamic Media Matrix Grid Module -->
            <section class="project-wrapper project">
                <div class="adaptive-media-grid">
                    {
                        currentGrid.map((item) => {
                            const isVideo =
                                item.type === "video" ||
                                Boolean(item.src?.match(/\.(mp4|webm|mov)$/i));
                            const isPlaceholder = item.type === "placeholder";

                            return (
                                <div
                                    class={`visual-container grid-span-${item.span}`}
                                >
                                    {isVideo ? (
                                        <video
                                            autoplay
                                            loop
                                            muted
                                            playsinline
                                            class="video bkg"
                                        >
                                            <source
                                                src={item.src}
                                                type="video/mp4"
                                            />
                                        </video>
                                    ) : isPlaceholder ? (
                                        <div class="div-block dark-room-fallback">
                                            <span class="button-label visual-badge-branding">
                                                {item.title}
                                            </span>
                                        </div>
                                    ) : (
                                        <img
                                            src={item.src}
                                            alt={
                                                item.title ||
                                                "Project Visual Content"
                                            }
                                            class="image bkg"
                                            loading="lazy"
                                        />
                                    )}
                                </div>
                            );
                        })
                    }
                </div>
            </section>

            <!-- Section 3: Split Detailed Copy & Credits Grid -->
            <section class="details-wrapper">
                <!-- Left Block: Overview & Description (7 Columns) -->
                <div class="description-container">
                    <h3 class="p-heading project-meta-label">
                        {entry.data.overviewTitle || "Overview"}
                    </h3>
                    <p class="paragraph about">
                        {
                            entry.data.description ||
                                "Transformative visual solutions designed around functional application frameworks, architectural spacing models, and strict system-driven parameter sets."
                        }
                    </p>
                    {
                        entry.data.links && (
                            <div class="project-links-group">
                                {entry.data.links.map((link) => (
                                    <a
                                        href={link.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="project-anchor-link"
                                    >
                                        {link.label} ↗
                                    </a>
                                ))}
                            </div>
                        )
                    }
                </div>

                <!-- Spacer Column (1 Column Gap) -->
                <div class="details-spacer"></div>

                <!-- Right Block: Credits (4 Columns) -->
                <div class="credits-container">
                    <h3 class="p-heading project-meta-label">
                        Project Credits
                    </h3>
                    <div class="project-meta-item">
                        <span class="button-label">Client / Context</span>
                        <p class="paragraph">
                            {entry.data.client || "Independent Exploration"}
                        </p>
                    </div>
                    <div class="project-meta-item">
                        <span class="button-label">Role / Scope</span>
                        <p class="paragraph">
                            {entry.data.role || "Design & Development"}
                        </p>
                    </div>
                    <div class="project-meta-item">
                        <span class="button-label">Timeline</span>
                        <p class="paragraph">
                            {entry.data.date || "2026 Build"}
                        </p>
                    </div>
                </div>
            </section>

            <!-- Section 4: Minimalist Return Footer -->
            <footer class="project-nav-footer-nav">
                <!-- Next Project Direct Link -->
                <a
                    href={`/projects/${nextProject.id}`}
                    class="project-nav w-inline-block"
                >
                    <h2 class="h1-global-title next-label">Next</h2>
                </a>

                <!-- Stacked Social Links -->
                <div class="footer-social-links">
                    <a href="mailto:hello@ikeriza.com" class="footer-word-link"
                        >Email</a
                    >
                    <a
                        href="https://www.linkedin.com/in/ikeriza/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="footer-word-link">LinkedIn</a
                    >
                    <a
                        href="https://www.instagram.com/iker.iza"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="footer-word-link">Instagram</a
                    >
                </div>

                <!-- Copyright Text Box -->
                <div class="footer-copyright">
                    <p>© by.iza 2026</p>
                </div>
            </footer>
        </main>
    </body>
</html>

<style>
    /* Viewport Framework Spacing Layout */
    .project-main-viewport {
        width: 100%;
        overflow-x: hidden;
        background-color: var(--swatches--black);
    }

    /* Full-bleed Header Block Styling */
    .project-hero-header {
        position: relative;
        width: 100%;
        height: 100dvh;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        margin: var(--scale--0);
    }

    .hero-bg-frame {
        position: absolute;
        inset: var(--scale--0);
        width: 100%;
        height: 100%;
        z-index: 1;
    }

    .hero-cover-src {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.65;
        display: block;
    }

    .hero-title-overlay {
        position: absolute;
        z-index: 2;
        padding: var(--scale--0) var(--scale--24);
        text-align: center;
        max-width: 90vw;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
    }

    /* Local overrides for sizing scales */
    .hero-dynamic-title {
        font-family: obviously-wide, sans-serif !important;
        font-weight: 900 !important;
        font-style: normal !important;
        text-transform: uppercase !important;
        font-size: var(--fontsize--heading-lg) !important;
        line-height: var(--line-height--heading-lg) !important;
        letter-spacing: var(--letter-space--heading-lg) !important;
        color: var(--swatches--white) !important;
        -webkit-text-fill-color: var(--swatches--white) !important;
    }

    /* Adaptive Media Base Grid System */
    .project-wrapper.project {
        padding: var(--scale--12) var(--scale--0) var(--scale--0)
            var(--scale--0);
    }

    .adaptive-media-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: var(--scale--12);
        width: 100%;
    }

    .visual-container {
        position: relative;
        overflow: hidden;
        border-radius: var(--scale--0);
        border: 0px solid rgba(255, 255, 255, 0.03);
        min-height: 35vw;
    }

    /* Span mapping calculations for rows containing 1, 2, 3, or 4 columns */
    .grid-span-1 {
        grid-column: span 12;
        max-height: 95dvh;
    }
    .grid-span-2 {
        grid-column: span 6;
        max-height: 65dvh;
    }
    .grid-span-3 {
        grid-column: span 4;
        max-height: 45dvh;
    }
    .grid-span-4 {
        grid-column: span 3;
        max-height: 45dvh;
    }

    .image.bkg,
    .video.bkg {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .dark-room-fallback {
        width: 100%;
        height: 100%;
        background-color: var(--swatches--800);
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .visual-badge-branding {
        color: var(--opacity--white);
        letter-spacing: var(--letter-space--button);
    }

    /* Details Grid (12-Column Grid Ratio: 7 / 1 Gap / 4 Columns) */
    .details-wrapper {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        padding: var(--scale--40) var(--scale--0);
        background-color: var(--swatches--black);
        border-top: 0px solid rgba(255, 255, 255, 0.05);
        width: 100%;
    }

    .description-container {
        grid-column: span 7;
        display: flex;
        flex-direction: column;
        gap: var(--scale--24);
    }

    .details-spacer {
        grid-column: span 1;
    }

    .credits-container {
        grid-column: span 4;
        display: flex;
        flex-direction: column;
        gap: var(--scale--24);
    }

    .project-meta-label {
        font-size: var(--fontsize--heading-sm);
        color: var(--color--brand);
        text-transform: uppercase;
        margin-bottom: var(--scale--16);
    }

    .project-meta-item {
        display: flex;
        flex-direction: column;
        gap: var(--scale--4);
    }

    /* Paragraph set to a single continuous column */
    .paragraph.about {
        column-count: 1;
        text-align: left;
    }

    .project-links-group {
        display: flex;
        gap: var(--scale--24);
        margin-top: var(--scale--16);
    }

    .project-anchor-link {
        color: var(--swatches--white);
        text-decoration: underline;
        font-size: var(--fontsize--paragraph);
        transition: color 0.3s ease;
    }

    .project-anchor-link:hover {
        color: var(--color--brand);
    }

    /* Footer Navigation Styling Blocks */
    .project-nav-footer-nav {
        padding: var(--scale--168) var(--scale--0) var(--scale--40)
            var(--scale--0);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--scale--80);
        text-align: center;
    }

    .project-nav {
        display: inline-block;
        cursor: pointer;
        text-decoration: none;
    }

    .next-label {
        color: var(--swatches--800);
        transition: color 0.4s ease;
        text-transform: none !important;
        font-family: obviously-wide, sans-serif !important;
        font-weight: 800 !important;
        font-style: normal !important;
        font-size: var(--fontsize--heading-lg) !important;
        line-height: var(--line-height--heading-lg) !important;
        letter-spacing: var(--letter-space--heading-lg) !important;
    }

    .project-nav:hover .next-label {
        color: var(--swatches--white);
    }

    /* Footer Social Word Links (Vertical Stack) */
    .footer-social-links {
        margin-top: var(--scale--168);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--scale--48);
    }

    .footer-word-link {
        font-family: var(--font-family--body);
        font-size: var(--scale--56);
        color: var(--swatches--white);
        text-decoration: none;
        transition: text-decoration 0.3s ease;
    }

    .footer-word-link:hover {
        text-decoration: underline;
    }

    /* Copyright Line */
    .footer-copyright {
        margin-top: var(--scale--80);
    }

    .footer-copyright p {
        font-family: var(--font-family--body);
        font-size: var(--scale--20);
        color: var(--swatches--white);
        margin: 0;
    }

    /* Media Responsive Layout Breakpoints */
    @media screen and (max-width: 991px) {
        .details-wrapper {
            padding: var(--scale--80) var(--scale--32);
        }
        .project-wrapper.project {
            padding: var(--scale--32) var(--scale--32) var(--scale--0)
                var(--scale--32);
        }
        .visual-container {
            min-height: 45vw;
        }
    }

    @media screen and (max-width: 768px) {
        .details-wrapper {
            display: flex;
            flex-direction: column;
            padding: var(--scale--64) var(--scale--16);
            gap: var(--scale--48);
        }
        .description-container,
        .credits-container {
            grid-column: span 12;
            width: 100%;
        }
        .details-spacer {
            display: none;
        }
        .footer-word-link {
            font-size: var(--scale--24);
        }
    }

    @media screen and (max-width: 479px) {
        .adaptive-media-grid {
            display: flex;
            flex-direction: column;
        }
        .visual-container {
            min-height: 65vw !important;
        }
        .project-wrapper.project {
            padding: var(--scale--16) var(--scale--16) var(--scale--0)
                var(--scale--16);
        }
        .project-links-group {
            flex-direction: column;
            gap: var(--scale--12);
        }
    }
</style>
