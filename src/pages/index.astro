<!-- Client-Side Automation Logic (Three.js + Scroll Interactions + Lottie) -->
<script>
    import * as THREE from "three";
    import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";
    import lottie from "lottie-web";

    // --- 1. Isolated Lottie Animation Hook ---
    try {
        const lottieContainer = document.getElementById("lottie-logo");
        if (lottieContainer) {
            lottieContainer.innerHTML = "";
            lottie.loadAnimation({
                container: lottieContainer,
                renderer: "svg",
                loop: true,
                autoplay: true,
                path: "/assets/lottie/logo-lottie.json",
            });
            console.log("Lottie successfully initialized.");
        }
    } catch (error) {
        console.error("Lottie initialization failed:", error);
    }

    // --- 2. Isolated Three.js 3D Title Handling ---
    try {
        const container = document.getElementById("threejs-container");
        if (container) {
            const scene = new THREE.Scene();
            const camera = new THREE.PerspectiveCamera(
                45,
                window.innerWidth / window.innerHeight,
                0.1,
                1000,
            );
            camera.position.set(0, 0, 8);

            const renderer = new THREE.WebGLRenderer({
                alpha: true,
                antialias: true,
            });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            container.appendChild(renderer.domElement);

            // Studio lighting setup
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambientLight);

            const keyLight = new THREE.DirectionalLight(0xffffff, 1.5);
            keyLight.position.set(5, 5, 5);
            scene.add(keyLight);

            const rimLight = new THREE.DirectionalLight(0xff4d4d, 1.0);
            rimLight.position.set(-5, 3, -5);
            scene.add(rimLight);

            // Initializing GLTFLoader
            const loader = new GLTFLoader();
            let meshModel: THREE.Group | null = null;

            loader.load(
                "/assets/models/logo-3d.glb",
                (gltf) => {
                    meshModel = gltf.scene;

                    // Center the model geometry automatically
                    const box = new THREE.Box3().setFromObject(meshModel);
                    const center = box.getCenter(new THREE.Vector3());
                    meshModel.position.sub(center);

                    scene.add(meshModel);
                    console.log("3D Model successfully loaded into scene.");
                },
                (xhr) => {
                    console.log(
                        `Model loading: ${((xhr.loaded / xhr.total) * 100).toFixed(0)}%`,
                    );
                },
                (error) => {
                    console.error("Error loading 3D asset model file:", error);
                },
            );

            // Mouse motion interaction listeners
            let mouseX = 0,
                mouseY = 0;
            window.addEventListener("mousemove", (e) => {
                mouseX = (e.clientX - window.innerWidth / 2) / 150;
                mouseY = (e.clientY - window.innerHeight / 2) / 150;
            });

            const animate = () => {
                requestAnimationFrame(animate);

                if (meshModel) {
                    meshModel.rotation.y +=
                        (mouseX - meshModel.rotation.y) * 0.05;
                    meshModel.rotation.x +=
                        (mouseY - meshModel.rotation.x) * 0.05;
                }

                renderer.render(scene, camera);
            };
            animate();

            // Responsive window scaling
            window.addEventListener("resize", () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
        }
    } catch (error) {
        console.error("Three.js setup encountered an error:", error);
    }

    // --- 3. Dynamic Area In-Viewport Scroll Background Switcher ---
    try {
        const bgContainer = document.getElementById("dynamic-bkg-container");
        const projectItems = document.querySelectorAll(".project-item");

        if (bgContainer && projectItems.length > 0) {
            const observerOptions = {
                root: null,
                rootMargin: "-20% 0px -20% 0px",
                threshold: 0.4,
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    const target = entry.target as HTMLElement;
                    const bgUrl = target.getAttribute("data-bg");
                    const textLink = target.querySelector(
                        ".project-nav",
                    ) as HTMLElement;

                    if (entry.isIntersecting) {
                        if (bgUrl) {
                            bgContainer.style.backgroundImage = `url('${bgUrl}')`;
                            bgContainer.style.opacity = "0.75";
                        }
                        if (textLink) {
                            textLink.style.color = "#ffffff";
                        }
                    } else {
                        if (textLink) {
                            textLink.style.color = "#838383";
                        }
                    }
                });
            }, observerOptions);

            projectItems.forEach((item) => observer.observe(item));
        }
    } catch (error) {
        console.error("Intersection Observer encountered an error:", error);
    }
</script>
