<section class="_3d-block">
    <div id="threejs-container"></div>
</section>

<style>
    ._3d-block {
        position: relative;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        background: transparent;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 5;
    }

    #threejs-container {
        width: 100%;
        height: 100%;
        position: absolute;
        top: 0;
        left: 0;
        z-index: 5;
        background: transparent;
    }
</style>

<script>
    import * as THREE from "three";
    import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";

    const container = document.getElementById("threejs-container");
    if (container) {
        try {
            const scene = new THREE.Scene();
            const camera = new THREE.PerspectiveCamera(
                40,
                window.innerWidth / window.innerHeight,
                0.1,
                1000,
            );
            camera.position.set(0, 0, 5.5);

            const renderer = new THREE.WebGLRenderer({
                alpha: true,
                antialias: true,
            });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.toneMapping = THREE.ACESFilmicToneMapping;
            renderer.toneMappingExposure = 1.3;
            container.appendChild(renderer.domElement);

            // Standard studio environment setup to serve as reflection data
            const pmremGenerator = new THREE.PMREMGenerator(renderer);
            pmremGenerator.compileEquirectangularShader();

            const envScene = new THREE.Scene();
            const roomMesh = new THREE.Mesh(
                new THREE.BoxGeometry(20, 20, 20),
                new THREE.MeshBasicMaterial({
                    color: 0x0a0a0a,
                    side: THREE.BackSide,
                }),
            );
            envScene.add(roomMesh);

            const envMapTarget = pmremGenerator.fromScene(envScene);
            scene.environment = envMapTarget.texture;

            // Balanced lighting vectors to softly illuminate the environment scenes
            scene.add(new THREE.AmbientLight(0xffffff, 0.5));
            const frontLight = new THREE.DirectionalLight(0xffffff, 1.0);
            frontLight.position.set(0, 4, 5);
            scene.add(frontLight);

            // Symmetrical layout anchor group container
            const modelPivotContainer = new THREE.Group();
            scene.add(modelPivotContainer);

            const loader = new GLTFLoader();
            let mixer: THREE.AnimationMixer | null = null;
            const clock = new THREE.Clock();

            loader.load(
                "/assets/models/logo-3d.glb",
                (gltf) => {
                    const loadedModel = gltf.scene;

                    // Compute true geometric bounds of the composite nodes
                    const box = new THREE.Box3().setFromObject(loadedModel);
                    const center = box.getCenter(new THREE.Vector3());
                    const size = box.getSize(new THREE.Vector3());

                    // Offset model pivot origins symmetrically onto true (0, 0, 0) coordinates
                    loadedModel.position.sub(center);

                    // Drop the model inside our calibrated anchor controller group
                    modelPivotContainer.add(loadedModel);

                    // Sizing constraints adjusted safely for screen footprints
                    const maxDim = Math.max(size.x, size.y, size.z);
                    const targetScale = 4.8 / maxDim;
                    modelPivotContainer.scale.set(
                        targetScale,
                        targetScale,
                        targetScale,
                    );

                    // Handles the play-once animation cycle setup
                    if (gltf.animations && gltf.animations.length > 0) {
                        mixer = new THREE.AnimationMixer(loadedModel);
                        gltf.animations.forEach((clip) => {
                            const action = mixer!.clipAction(clip);

                            // CONFIGURE PLAY ONCE: Kill loop state and lock final frame execution
                            action.loop = THREE.LoopOnce;
                            action.clampWhenFinished = true;

                            action.play();
                        });
                    }
                },
                undefined,
                (err) => console.error("glTF parsing crashed:", err),
            );

            // Calibrated smooth tracking dynamics
            let targetMouseX = 0,
                targetMouseY = 0;
            let currentMouseX = 0,
                currentMouseY = 0;

            window.addEventListener("mousemove", (e) => {
                targetMouseX = (e.clientX - window.innerWidth / 2) / 900;
                targetMouseY = (e.clientY - window.innerHeight / 2) / 900;
            });

            const animate = () => {
                requestAnimationFrame(animate);
                const delta = clock.getDelta();

                if (mixer) mixer.update(delta);

                if (modelPivotContainer) {
                    currentMouseX += (targetMouseX - currentMouseX) * 0.05;
                    currentMouseY += (targetMouseY - currentMouseY) * 0.05;

                    modelPivotContainer.rotation.y = currentMouseX;
                    modelPivotContainer.rotation.x = currentMouseY;
                }

                renderer.render(scene, camera);
            };
            animate();

            window.addEventListener("resize", () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
        } catch (error) {
            console.error("Three.js setup initialization crashed:", error);
        }
    }
</script>
