---
import { getCollection } from "astro:content";
const portfolioProjects = await getCollection("projects");
---

<section class="project-wrapper home">
    <div class="project-grid _1-col">
        {
            portfolioProjects.map((project) => (
                <div
                    class="title-container project-item"
                    data-bg={project.data.heroImage}
                >
                    <a href={`/projects/${project.id}`} class="w-inline-block">
                        <h1 class="project-nav">{project.data.title}</h1>
                    </a>
                </div>
            ))
        }
    </div>
</section>

<style>
    .project-wrapper {
        position: relative;
        z-index: 10;
        /* Using 50vh to center, but horizontal margins map to your system tokens */
        padding: 50vh var(--body--padding);
        background: transparent;
    }

    .project-grid {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--scale--0); /* Tied to system zero scale */
    }

    .title-container {
        padding: var(
            --scale--0
        ); /* Crushed padding completely using design token */
        text-align: center;
        width: 100%;
        cursor: pointer;
        position: relative;
        z-index: 20;
    }

    .project-nav {
        font-size: var(
            --fontsize--heading-lg
        ); /* Connected directly to token (14vw) */
        text-transform: uppercase;
        color: var(
            --opacity--white
        ); /* Sets 15% opacity baseline directly via token */
        transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        font-family: var(--font-family--heading);
        font-weight: 900;
        line-height: var(--line-height--heading-lg); /* Maps to .785em */
        letter-spacing: var(--letter-space--heading-lg); /* Maps to -.015em */
        margin: var(--scale--0);
    }
</style>

<script>
    const bgContainer = document.getElementById(
        "dynamic-bkg-container",
    ) as HTMLElement | null;
    const projectItems = document.querySelectorAll(".project-item");

    if (bgContainer && projectItems.length > 0) {
        try {
            const observerOptions = {
                root: null,
                rootMargin: "-40% 0px -40% 0px",
                threshold: 0.1,
            };

            let currentlyActiveItem: HTMLElement | null = null;

            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    const target = entry.target as HTMLElement;
                    const bgUrl = target.getAttribute("data-bg");
                    const textLink = target.querySelector(
                        ".project-nav",
                    ) as HTMLElement | null;

                    if (entry.isIntersecting) {
                        currentlyActiveItem = target;

                        if (bgUrl) {
                            bgContainer.style.backgroundImage = `url('${bgUrl}')`;
                            bgContainer.style.opacity = "0.45";
                        }
                        if (textLink)
                            textLink.style.color = "var(--swatches--white)"; // Fades up to solid white token
                    } else {
                        if (textLink)
                            textLink.style.color = "var(--opacity--white)"; // FIXED: Now cleanly falls back to 15% opacity design variable

                        if (currentlyActiveItem === target) {
                            bgContainer.style.opacity = "0";
                            currentlyActiveItem = null;
                        }
                    }
                });
            }, observerOptions);

            projectItems.forEach((item) => observer.observe(item));
        } catch (error) {
            console.error("Intersection Observer loop crashed:", error);
        }
    }
</script>
