---
interface Props {
    title?: string;
}

const { title = "Iker Iza - NYC | Brand Development & Creative Direction" } =
    Astro.props;
---

<!doctype html>
<html lang="en-US">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <meta
            name="description"
            content="Experience in Branding, Packaging, Web, Apps, Events, Virtual Reality, and more."
        />

        <!-- Webflow Styles & Plyr Audio/Video Layout Styles -->
        <link
            rel="stylesheet"
            href="/assets/css/portfolio2024-e2f0a3.webflow.shared.ab580fd63.min.css"
        />
        <link rel="stylesheet" href="/assets/css/plyr.css" />

        <!-- Adobe Typekit Typography Engine (Obviously Font Family Injection) -->
        <link rel="stylesheet" href="https://use.typekit.net/lmi7yvo.css" />
        <script is:inline src="https://use.typekit.net/lmi7yvo.js"></script>
        <script is:inline>
            try {
                Typekit.load();
            } catch (e) {}
        </script>

        <!-- Google Typography Engine (Victor Mono Font Family Injection) -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Victor+Mono:ital,wght@1,700&display=swap"
        />

        <!-- Google Tag Engine Analytics Injections (gtag.js) -->
        <script
            is:inline
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-WQ92F84BL4"
        ></script>
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", "G-WQ92F84BL4");
        </script>
    </head>
    <body class="body">
        <slot />

        <!-- Core Global Engineering Scripts Sourced via Reliable Production CDNs -->
        <script is:inline src="https://code.jquery.com/jquery-3.5.1.min.js"
        ></script>
        <script
            is:inline
            src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
        ></script>
        <script is:inline src="https://cdn.plyr.io/3.5.6/plyr.js"></script>
        <script is:inline>
            document.addEventListener("DOMContentLoaded", () => {
                document
                    .querySelectorAll(".js-player")
                    .forEach((p) => new Plyr(p));
            });
        </script>
    </body>
</html>
